---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Card from "../../components/Card.astro";
import { getCollection } from "astro:content";

const projects = (await getCollection("projects")).sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime()
);
---

<BaseLayout title="作品集 | CallStorm" description="项目、技术栈和成果展示。">
  <section class="page-header">
    <p class="eyebrow">Projects</p>
    <h1>作品集</h1>
  </section>

  <section class="grid">
    {projects.map((project) => (
      <Card
        title={project.data.title}
        description={project.data.summary}
        href={project.data.repo ?? `/projects/${project.id}`}
        tags={project.data.tech}
        cover={project.data.cover}
        icon="github"
        ctaLabel={project.data.repo ? "View on GitHub" : "View Project"}
        external={Boolean(project.data.repo)}
      />
    ))}
  </section>
</BaseLayout>
